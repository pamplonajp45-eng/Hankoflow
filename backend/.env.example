FRONTEND_URLS=http://localhost:5173,https://your-frontend.vercel.app
PUBLIC_API_URL=http://localhost:5000
PUBLIC_FRONTEND_URL=http://localhost:5173

# Database: use DATABASE_URL for Supabase.
# Recommended for local development: Supabase transaction pooler.
# Copy the exact string from Supabase:
# Project Settings -> Database -> Connection string -> Transaction pooler.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@POOLER_HOST:6543/postgres
#
# Alternative direct connection. This may fail on networks without IPv6 support.
# DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.lcfadiceswkkokyvvgoc.supabase.co:5432/postgres
#
# Local Postgres fallback only:
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Fallback approval chain. The employee can override these per request in the app.
APPROVER_LEVEL_1_EMAIL=pamplonajeypii.45@outlook.com
APPROVER_LEVEL_2_EMAIL=assistantmanager@company.com
APPROVER_LEVEL_3_EMAIL=manager@company.com

# Optional legacy Supabase Edge Function mailer. Leave blank for the manual Outlook flow.
SUPABASE_APPROVAL_MAILER_URL=
SUPABASE_FUNCTION_AUTH_TOKEN=
